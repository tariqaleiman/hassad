rules_version = '2';

// قواعد أمان مشروع "حصاد" — Multi-Tenancy (تعدد المستخدمين)
// المبدأ: البيانات معزولة بالكامل، ولا يحق لأي مستخدم الوصول إلا للبيانات التي أنشأها

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    function isOwnerCreate() {
      return isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    function isOwnerUpdate() {
      return isOwner() && request.resource.data.createdBy == request.auth.uid;
    }

    // ملفات المستخدمين (الملف الشخصي والإعدادات)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // تطبيق قاعدة العزل (Owner Only) على كل الكيانات
    match /farms/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /lands/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /seasons/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /crops/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /cropCycles/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /operations/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /inventoryItems/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /suppliers/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /customers/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /debts/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /payments/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /expenses/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /revenues/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /workers/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /equipment/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwner();
    }

    match /activityLog/{document} {
      allow create: if isOwnerCreate();
      allow read: if isOwner();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

